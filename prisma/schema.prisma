generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Five {
  five_id  Int    @id @default(autoincrement())
  f_year   Int
  f_week   Int
  f_total  BigInt
  f_first  Int
  f_second Int
  f_third  Int
  f_fourth Int
  f_fifth  Int

  @@index([f_first, f_second, f_third, f_fourth, f_fifth])
  @@map("five")
}

model Six {
  six_id   Int    @id @default(autoincrement())
  s_year   Int
  s_week   Int
  s_total  BigInt
  s_first  Int
  s_second Int
  s_third  Int
  s_fourth Int
  s_fifth  Int
  s_sixth  Int

  @@index([s_first, s_second, s_third, s_fourth, s_fifth, s_sixth])
  @@map("six")
}

model Skandi {
  sk_id     Int    @id @default(autoincrement())
  sk_year   Int
  sk_week   Int
  sk_total  BigInt
  m_first   Int
  m_second  Int
  m_third   Int
  m_fourth  Int
  m_fifth   Int
  m_sixth   Int
  m_seventh Int
  h_first   Int
  h_second  Int
  h_third   Int
  h_fourth  Int
  h_fifth   Int
  h_sixth   Int
  h_seventh Int

  @@index([m_first, m_second, m_third, m_fourth, m_fifth, m_sixth, m_seventh])
  @@index([h_first, h_second, h_third, h_fourth, h_fifth, h_sixth, h_seventh])
  @@map("skandi")
}
